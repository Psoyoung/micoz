# MICOZ Backend - Environment Variables Example
# Copy this file to `.env` and fill in real values for local development.
# NEVER commit `.env` to the repository.

# --- Spring Profile ---
SPRING_PROFILES_ACTIVE=local

# --- Database (PostgreSQL 15) ---
DB_URL=jdbc:postgresql://localhost:5432/micoz
DB_USERNAME=micoz
DB_PASSWORD=micoz

# --- Server ---
SERVER_PORT=8080

# --- JWT (M1 reserved; must be >= 256-bit / 32 chars) ---
JWT_SECRET=please-change-me-to-a-long-random-secret-at-least-32-chars

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- First admin bootstrap (F-T1) ---
# 운영 관리자가 하나도 없을 때 기동 시 1회 시드된다. 값을 채우면 BCrypt 해시로 저장된다.
# 평문 비밀번호는 절대 커밋하지 말 것 (.env 는 gitignore 대상). 비워두면 시드를 건너뛴다.
ADMIN_INIT_USER_ID=admin
ADMIN_INIT_USER_NAME=운영관리자
ADMIN_INIT_PASSWORD=
ADMIN_INIT_EMAIL=

# --- PostgreSQL container (used by docker-compose) ---
POSTGRES_DB=micoz
POSTGRES_USER=micoz
POSTGRES_PASSWORD=micoz
